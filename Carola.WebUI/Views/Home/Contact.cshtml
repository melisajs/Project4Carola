@model Carola.WebUI.Models.ContactPageViewModel
@{
    ViewData["Title"] = T.Translate("İletişim", "Contact");
}

<header class="page-hero page-hero-contact">
    <div class="container page-hero-content">
        <span class="page-kicker"><i class="bi bi-chat-heart"></i> @T.Translate("Size Yardımcı Olalım", "Let Us Help")</span>
        <h1>@T.Translate("Sorunuz mu var? Bize ulaşın.", "Have a question? Get in touch.")</h1>
        <p>@T.Translate("Rezervasyon, araç seçimi veya yolculuğunuzla ilgili tüm sorularınız için Carola ekibi yanınızda.", "The Carola team is ready to help with booking, vehicle selection and every part of your journey.")</p>
        <div class="page-breadcrumb"><a asp-action="Index">@T.Translate("Ana Sayfa", "Home")</a><i class="bi bi-chevron-right"></i><span>@T.Translate("İletişim", "Contact")</span></div>
    </div>
</header>

<main class="contact-page">
    <section class="container contact-quick-grid">
        <a href="tel:+908503602652" class="contact-quick-card"><i class="bi bi-telephone-outbound"></i><span>@T.Translate("Bizi Arayın", "Call Us")</span><strong>+90 850 360 26 52</strong><small>@T.Translate("Her gün 08.00 - 22.00", "Every day 08:00 - 22:00")</small></a>
        <a href="mailto:info@carola.com" class="contact-quick-card"><i class="bi bi-envelope-paper"></i><span>@T.Translate("E-posta Gönderin", "Send an Email")</span><strong>info@carola.com</strong><small>@T.Translate("En geç 24 saat içinde yanıt", "Reply within 24 hours")</small></a>
        <div class="contact-quick-card"><i class="bi bi-geo-alt"></i><span>@T.Translate("Merkez Ofis", "Head Office")</span><strong>@T.Translate("İstanbul, Türkiye", "Istanbul, Türkiye")</strong><small>@T.Translate("Maslak / Sarıyer", "Maslak / Sariyer")</small></div>
    </section>

    <section class="container contact-main-grid">
        <div class="contact-form-card">
            <span class="section-subtitle text-start">@T.Translate("Mesaj Gönderin", "Send a Message")</span>
            <h2>@T.Translate("Sizi dinliyoruz", "We are listening")</h2>
            <p>@T.Translate("Formu doldurun, müşteri deneyimi ekibimiz en kısa sürede size dönüş yapsın.", "Complete the form and our customer experience team will get back to you shortly.")</p>

            @if (TempData["ContactSuccess"] is string successMessage)
            {
                <div class="contact-success" role="alert"><i class="bi bi-check-circle-fill"></i><div><strong>@T.Translate("Mesajınız gönderildi", "Message sent")</strong><span>@successMessage</span></div></div>
            }

            <form asp-action="Contact" method="post" class="contact-form" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="contact-form-row">
                    <div><label asp-for="FullName">@T.Translate("Ad Soyad", "Full Name") *</label><input asp-for="FullName" class="form-control" placeholder="@T.Translate("Adınız ve soyadınız", "Your full name")" /><span asp-validation-for="FullName" class="text-danger small"></span></div>
                    <div><label asp-for="Email">@T.Translate("E-posta", "Email") *</label><input asp-for="Email" class="form-control" placeholder="ornek@email.com" /><span asp-validation-for="Email" class="text-danger small"></span></div>
                </div>
                <div class="contact-form-row">
                    <div><label asp-for="Phone">@T.Translate("Telefon", "Phone")</label><input asp-for="Phone" class="form-control" placeholder="+90 5xx xxx xx xx" /><span asp-validation-for="Phone" class="text-danger small"></span></div>
                    <div><label asp-for="Subject">@T.Translate("Konu", "Subject") *</label><input asp-for="Subject" class="form-control" placeholder="@T.Translate("Size nasıl yardımcı olabiliriz?", "How can we help?")" /><span asp-validation-for="Subject" class="text-danger small"></span></div>
                </div>
                <div><label asp-for="Message">@T.Translate("Mesajınız", "Your Message") *</label><textarea asp-for="Message" class="form-control" rows="6" placeholder="@T.Translate("Mesajınızı buraya yazın...", "Write your message here...")"></textarea><span asp-validation-for="Message" class="text-danger small"></span></div>
                <button type="submit" class="btn btn-primary btn-primary-custom contact-submit">@T.Translate("Mesajı Gönder", "Send Message") <i class="bi bi-send"></i></button>
            </form>
        </div>

        <aside class="contact-side-card">
            <div class="contact-side-visual"><i class="bi bi-headset"></i><h3>@T.Translate("Carola Destek", "Carola Support")</h3><p>@T.Translate("Yolculuğunuzun her adımında gerçek bir ekip yanınızda.", "A real team is by your side at every step of your journey.")</p></div>
            <div class="contact-office"><h4>@T.Translate("Merkez Ofis", "Head Office")</h4><p><i class="bi bi-geo-alt"></i>@T.Translate("Maslak Mah. Büyükdere Cad. No: 245", "Maslak District, Buyukdere Ave. No: 245")<br />@T.Translate("Sarıyer / İstanbul", "Sariyer / Istanbul")</p><p><i class="bi bi-clock"></i>@T.Translate("Pazartesi - Cuma: 08.00 - 18.00", "Monday - Friday: 08:00 - 18:00")</p></div>
        </aside>
    </section>

    @if (Model.Branches.Any())
    {
        <section class="container contact-branches">
            <div class="section-subtitle">@T.Translate("Şubelerimiz", "Our Branches")</div>
            <h2 class="section-title">@T.Translate("Size en yakın Carola noktası", "Find your nearest Carola location")</h2>
            <div class="contact-branch-grid">
                @foreach (var branch in Model.Branches)
                {
                    <article><i class="bi bi-pin-map"></i><div><h3>@T.Data(branch.LocationName)</h3><span>@T.Translate("Araç teslim ve iade noktası", "Pick-up and return location")</span></div><a asp-controller="Car" asp-action="CarList" asp-route-locationId="@branch.LocationId" aria-label="@T.Data(branch.LocationName)"><i class="bi bi-arrow-up-right"></i></a></article>
                }
            </div>
        </section>
    }
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
