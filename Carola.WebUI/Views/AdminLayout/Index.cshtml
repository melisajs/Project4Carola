                flex-wrap: wrap;
                padding-top: 0.8rem;
                border-top: 1px solid rgba(148, 163, 184, 0.08);
            }

            .branch-info {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                color: rgba(237, 244, 255, 0.74);
                font-size: 0.88rem;
                font-weight: 600;
            }

                .branch-info i {
                    color: var(--accent);
                }

            .action-group {
                display: flex;
                gap: 0.55rem;
                flex-wrap: wrap;
            }

            .btn-soft,
            .btn-danger-soft,
            .btn-outline-light {
                padding: 0.62rem 0.82rem;
                font-size: 0.82rem;
            }

            .btn-soft {
                color: #d9fffa;
                background: rgba(57, 219, 200, 0.12);
                border: 1px solid rgba(57, 219, 200, 0.18);
            }

                .btn-soft:hover {
                    color: #fff;
                    background: rgba(57, 219, 200, 0.20);
                    border-color: rgba(57, 219, 200, 0.28);
                    transform: translateY(-2px);
                }

            .btn-danger-soft {
                color: #ffe0e0;
                background: rgba(255, 112, 112, 0.12);
                border: 1px solid rgba(255, 112, 112, 0.18);
            }

                .btn-danger-soft:hover {
                    color: #fff;
                    background: rgba(255, 112, 112, 0.18);
                    border-color: rgba(255, 112, 112, 0.26);
                    transform: translateY(-2px);
                }

            .empty-state {
                text-align: center;
                padding: 3rem 1rem;
            }

            .empty-icon {
                width: 84px;
                height: 84px;
                border-radius: 26px;
                margin: 0 auto 1rem;
                display: grid;
                place-items: center;
                background: rgba(148, 163, 184, 0.08);
                border: 1px solid rgba(148, 163, 184, 0.12);
                color: var(--accent);
                font-size: 2rem;
