            .empty-state h3 {
                margin: 0 0 0.4rem;
                font-size: 1.35rem;
                font-weight: 800;
            }

            .empty-state p {
                margin: 0;
                color: var(--muted);
            }

            /* Modal / Toast */
            .modal-shell {
                background: linear-gradient(180deg, rgba(16, 25, 43, 0.98), rgba(10, 18, 31, 0.98));
                border: 1px solid rgba(148, 163, 184, 0.16);
                border-radius: 26px;
                color: var(--text);
                box-shadow: var(--shadow-lg);
            }

            .modal-header,
            .modal-footer {
                border-color: rgba(148, 163, 184, 0.10);
            }

            .form-control,
            .form-select {
                min-height: 50px;
                border-radius: 14px;
                border: 1px solid rgba(148, 163, 184, 0.12);
                background: rgba(148, 163, 184, 0.06);
                color: var(--text);
            }

                .form-control:focus,
                .form-select:focus {
                    color: var(--text);
                    background: rgba(148, 163, 184, 0.08);
                    border-color: rgba(57, 219, 200, 0.40);
                    box-shadow: 0 0 0 0.18rem rgba(57, 219, 200, 0.14);
                }

                .form-control::placeholder {
                    color: rgba(148, 163, 184, 0.72);
                }

            .form-label {
                color: rgba(237, 244, 255, 0.8);
                font-size: 0.86rem;
                font-weight: 700;
                margin-bottom: 0.45rem;
            }

            .toast-shell {
                background: rgba(10, 18, 31, 0.95);
                border: 1px solid rgba(148, 163, 184, 0.14);
                border-radius: 18px;
                color: var(--text);
                box-shadow: var(--shadow-md);
            }

            /* Sidebar collapsed */
            body.sidebar-collapsed .sidebar {
                width: var(--sidebar-mini);
                padding-inline: 0.78rem;
            }

            body.sidebar-collapsed .main-panel {
                width: calc(100% - var(--sidebar-mini));
                margin-left: var(--sidebar-mini);
            }

            body.sidebar-collapsed .brand-copy,
            body.sidebar-collapsed .nav-title,
            body.sidebar-collapsed .menu-label,
            body.sidebar-collapsed .menu-arrow,
            body.sidebar-collapsed .submenu,
            body.sidebar-collapsed .sidebar-note {
                opacity: 0;
                visibility: hidden;
                pointer-events: none;
                max-height: 0;
                margin: 0;
                transform: translateX(-10px);
            }

            body.sidebar-collapsed .menu-link,
            body.sidebar-collapsed .menu-toggle {
                justify-content: center;
                padding-inline: 0.8rem;
            }

            body.sidebar-collapsed .sidebar-header,
            body.sidebar-collapsed .brand {
                justify-content: center;
            }

            body.sidebar-collapsed .menu-link:hover,
            body.sidebar-collapsed .menu-toggle:hover {
                transform: translateY(-2px);
            }

            .sidebar-backdrop {
                position: fixed;
                inset: 0;
                background: rgba(4, 8, 16, 0.58);
                opacity: 0;
                visibility: hidden;
                transition: opacity var(--transition), visibility var(--transition);
                z-index: 1050;
            }

            /* Responsive */
            @@media (max-width: 1399.98px) {
                .spec-grid {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                }
            }

            @@media (max-width: 1199.98px) {
                .hero {
                    grid-template-columns: 1fr;
                }

                .hero-stats {
                    width: 100%;
                }
            }

            @@media (max-width: 991.98px) {
                .sidebar {
                    width: min(86vw, 320px);
                    transform: translateX(-104%);
                }

                .main-panel {
                    width: 100%;
                    margin-left: 0;
                }

                body.sidebar-mobile-open .sidebar {
                    transform: translateX(0);
                }

                body.sidebar-mobile-open .sidebar-backdrop {
                    opacity: 1;
                    visibility: visible;
                }

                .topbar {
                    padding: 1rem;
                }

                .content {
                    padding: 1rem 1rem 1.75rem;
                }

                .profile-copy {
                    display: none;
                }
            }

            @@media (max-width: 767.98px) {
                .hero,
                .toolbar {
                    padding: 1.2rem;
                }

                .hero-stats {
                    grid-template-columns: 1fr;
                }

                .spec-grid {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                }

                .vehicle-footer {
                    flex-direction: column;
                    align-items: stretch;
                }

                .action-group {
                    width: 100%;
                }

                    .action-group .btn {
                        flex: 1 1 calc(50% - 0.3rem);
                    }
            }

            @@media (max-width: 575.98px) {
                .icon-btn {
                    width: 42px;
                    height: 42px;
                    border-radius: 14px;
                }

                .hero h1 {
                    font-size: 1.8rem;
                }

                .spec-grid {
                    grid-template-columns: 1fr;
                }

                .action-group .btn {
                    flex: 1 1 100%;
                }
            }
    </style>
</head>
