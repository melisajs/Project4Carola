@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Carola | Admin Panel</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>
            :root {
                --bg: #07111f;
                --bg-2: #0c1729;
                --panel: rgba(13, 22, 37, 0.92);
                --panel-2: rgba(11, 18, 31, 0.98);
                --line: rgba(148, 163, 184, 0.14);
                --line-strong: rgba(148, 163, 184, 0.24);
                --text: #edf4ff;
                --muted: #8fa3be;
                --accent: #39dbc8;
                --accent-2: #ffb75d;
                --success: #46dd96;
                --warning: #f6ba54;
                --danger: #ff6f6f;
                --sidebar-width: 292px;
                --sidebar-mini: 92px;
                --topbar-height: 86px;
                --radius-xl: 28px;
                --radius-lg: 22px;
                --radius-md: 16px;
                --shadow-lg: 0 26px 72px rgba(2, 8, 18, 0.42);
                --shadow-md: 0 16px 40px rgba(2, 8, 18, 0.26);
                --transition: 0.35s ease;
            }

            * {
                box-sizing: border-box;
            }

            html,
            body {
                margin: 0;
                padding: 0;
            }

            body {
                min-height: 100vh;
                font-family: "Manrope", sans-serif;
                color: var(--text);
                background: radial-gradient(circle at top left, rgba(57, 219, 200, 0.16), transparent 28%), radial-gradient(circle at bottom right, rgba(255, 183, 93, 0.12), transparent 24%), linear-gradient(145deg, #040a14 0%, #091321 42%, #0c1629 100%);
                overflow-x: hidden;
            }

                body::before {
                    content: "";
                    position: fixed;
                    inset: 0;
                    background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
                    background-size: 48px 48px;
                    mask-image: linear-gradient(180deg, rgba(0,0,0,0.65), transparent 94%);
                    pointer-events: none;
                    z-index: -1;
                }

            a {
                text-decoration: none;
                color: inherit;
            }

            .glass {
                background: linear-gradient(180deg, rgba(16, 25, 43, 0.94), rgba(10, 18, 31, 0.96));
                border: 1px solid var(--line);
                border-radius: var(--radius-lg);
                box-shadow: var(--shadow-md);
                backdrop-filter: blur(18px);
            }

            .app-shell {
                display: flex;
                min-height: 100vh;
            }

            /* Sidebar */
            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                z-index: 1100;
                width: var(--sidebar-width);
                height: 100vh;
                padding: 1.2rem 1rem;
                background: rgba(6, 13, 24, 0.95);
                border-right: 1px solid rgba(148, 163, 184, 0.10);
                backdrop-filter: blur(24px);
                box-shadow: 24px 0 60px rgba(2, 8, 18, 0.34);
                display: flex;
                flex-direction: column;
                transition: width var(--transition), transform var(--transition), padding var(--transition);
            }

            .sidebar-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 0.75rem;
                margin-bottom: 1.4rem;
            }

            .brand {
                display: flex;
                align-items: center;
                gap: 0.9rem;
                min-width: 0;
            }

            .brand-mark {
                width: 52px;
                height: 52px;
                border-radius: 18px;
                display: grid;
                place-items: center;
                background: linear-gradient(135deg, rgba(57, 219, 200, 0.22), rgba(255, 183, 93, 0.22));
                border: 1px solid rgba(57, 219, 200, 0.20);
                color: var(--accent);
                font-size: 1.35rem;
                flex-shrink: 0;
            }

            .brand-copy {
                min-width: 0;
                transition: opacity var(--transition), transform var(--transition);
            }

                .brand-copy strong {
                    display: block;
                    font-size: 1rem;
                    font-weight: 800;
                    letter-spacing: 0.02em;
                }

                .brand-copy span {
                    display: block;
                    color: var(--muted);
                    font-size: 0.77rem;
                    letter-spacing: 0.12em;
                    text-transform: uppercase;
                }

            .sidebar-scroll {
                display: flex;
                flex-direction: column;
                gap: 1.2rem;
                overflow-y: auto;
                padding-right: 0.2rem;
            }

                .sidebar-scroll::-webkit-scrollbar {
                    width: 8px;
                }

                .sidebar-scroll::-webkit-scrollbar-thumb {
                    background: rgba(148, 163, 184, 0.12);
                    border-radius: 999px;
                }

            .nav-title {
                margin: 0 0 0.55rem;
                padding-left: 0.9rem;
                color: rgba(237, 244, 255, 0.46);
                font-size: 0.72rem;
                font-weight: 800;
                letter-spacing: 0.14em;
                text-transform: uppercase;
            }

            .menu-link,
            .menu-toggle,
            .submenu-link {
                width: 100%;
                display: flex;
                align-items: center;
                gap: 0.9rem;
                padding: 0.9rem 1rem;
                border-radius: 16px;
                border: 0;
                background: transparent;
                color: rgba(237, 244, 255, 0.82);
                font-weight: 600;
                transition: transform var(--transition), background var(--transition), border-color var(--transition), color var(--transition);
            }

                .menu-link:hover,
                .menu-toggle:hover,
                .submenu-link:hover {
                    color: #fff;
                    background: rgba(148, 163, 184, 0.08);
                    transform: translateX(4px);
                }

                .menu-link.active,
                .menu-toggle.active,
                .submenu-link.active {
                    color: #fff;
                    background: linear-gradient(135deg, rgba(57, 219, 200, 0.18), rgba(57, 219, 200, 0.06));
                    border: 1px solid rgba(57, 219, 200, 0.22);
                    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
                }

                .menu-link i,
                .menu-toggle i:first-child {
                    font-size: 1.05rem;
                    flex-shrink: 0;
                }

            .menu-label {
                flex: 1;
                text-align: left;
                white-space: nowrap;
                transition: opacity var(--transition), transform var(--transition);
            }

            .menu-arrow {
                font-size: 0.82rem;
                transition: transform var(--transition), opacity var(--transition);
            }

            .menu-toggle[aria-expanded="true"] .menu-arrow {
                transform: rotate(180deg);
            }

            .submenu {
                padding: 0.35rem 0 0.15rem 2.2rem;
                transition: opacity var(--transition), transform var(--transition);
            }


            .submenu-link {
                font-size: 0.94rem;
                padding: 0.72rem 0.92rem;
                color: rgba(237, 244, 255, 0.68);
                position: relative;
            }
            .submenu-button {
                border: 0;
                width: 100%;
                text-align: left;
                cursor: pointer;
            }

                 .submenu-link::before {
                    content: "";
                    width: 6px;
                    height: 6px;
                    border-radius: 50%;
                    background: rgba(57, 219, 200, 0.58);
                    margin-right: 0.15rem;
                    flex-shrink: 0;
                }

            .sidebar-note {
                margin-top: auto;
                padding: 1.05rem;
                border-radius: 22px;
                background: linear-gradient(180deg, rgba(18, 29, 47, 0.98), rgba(12, 20, 35, 0.95)), linear-gradient(135deg, rgba(57, 219, 200, 0.12), rgba(255, 183, 93, 0.12));
                border: 1px solid rgba(148, 163, 184, 0.12);
                position: relative;
                overflow: hidden;
            }

                .sidebar-note::after {
                    content: "";
                    position: absolute;
                    right: -18px;
                    bottom: -36px;
                    width: 120px;
                    height: 120px;
                    background: radial-gradient(circle, rgba(57, 219, 200, 0.16), transparent 72%);
                    pointer-events: none;
                }

                .sidebar-note small {
                    display: inline-flex;
                    align-items: center;
                    gap: 0.4rem;
                    margin-bottom: 0.45rem;
                    color: var(--accent);
                    font-size: 0.68rem;
                    font-weight: 800;
                    text-transform: uppercase;
                    letter-spacing: 0.12em;
                }

                .sidebar-note h4 {
                    margin: 0 0 0.45rem;
                    font-size: 1rem;
                    font-weight: 700;
                }

                .sidebar-note p {
                    margin: 0;
                    color: var(--muted);
                    font-size: 0.84rem;
                    line-height: 1.55;
                }

            /* Main */
            .main-panel {
                width: calc(100% - var(--sidebar-width));
                margin-left: var(--sidebar-width);
                min-height: 100vh;
                transition: margin-left var(--transition), width var(--transition);
            }

            .topbar {
                position: sticky;
                top: 0;
                z-index: 1200;
                min-height: var(--topbar-height);
                padding: 1.1rem 1.4rem;
                display: flex;
                align-items: center;
                gap: 1rem;
                background: rgba(8, 16, 30, 0.74);
                border-bottom: 1px solid rgba(148, 163, 184, 0.08);
                backdrop-filter: blur(16px);
            }

            .topbar-search {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                width: min(100%, 360px);
                padding: 0.88rem 1rem;
                border-radius: 18px;
                background: rgba(148, 163, 184, 0.08);
                border: 1px solid rgba(148, 163, 184, 0.10);
                color: var(--muted);
            }

                .topbar-search input,
                .search-box input {
                    width: 100%;
                    border: 0;
                    outline: 0;
                    background: transparent;
                    color: var(--text);
                    font-size: 0.95rem;
                }

                    .topbar-search input::placeholder,
                    .search-box input::placeholder {
                        color: rgba(148, 163, 184, 0.72);
                    }

            .topbar-actions {
                display: flex;
                align-items: center;
                gap: 0.8rem;
                margin-left: auto;
            }

            .quick-pill {
                display: inline-flex;
                align-items: center;
                gap: 0.55rem;
                padding: 0.82rem 1rem;
                border-radius: 16px;
                background: rgba(148, 163, 184, 0.08);
                border: 1px solid rgba(148, 163, 184, 0.10);
                color: rgba(237, 244, 255, 0.92);
                font-size: 0.88rem;
                font-weight: 600;
            }

                .quick-pill i {
                    color: var(--accent-2);
                }

            .icon-btn,
            .profile-btn {
                border: 1px solid rgba(148, 163, 184, 0.12);
                background: rgba(148, 163, 184, 0.08);
                color: var(--text);
                transition: transform var(--transition), background var(--transition), border-color var(--transition);
            }

            .icon-btn {
                width: 46px;
                height: 46px;
                display: inline-grid;
                place-items: center;
                border-radius: 16px;
                font-size: 1.05rem;
            }

                .icon-btn:hover,
                .profile-btn:hover {
                    transform: translateY(-2px);
                    background: rgba(57, 219, 200, 0.12);
                    border-color: rgba(57, 219, 200, 0.22);
                }

            .notif-dot {
                position: absolute;
                top: 9px;
                right: 9px;
                min-width: 18px;
                height: 18px;
                padding: 0 0.25rem;
                display: grid;
                place-items: center;
                border-radius: 999px;
                background: linear-gradient(135deg, var(--danger), #ff9070);
                color: #fff;
                font-size: 0.62rem;
                font-weight: 800;
                border: 2px solid #091323;
            }

            .profile-btn {
                display: inline-flex;
                align-items: center;
                gap: 0.75rem;
                padding: 0.45rem 0.55rem;
                border-radius: 18px;
            }

                .profile-btn img {
                    width: 38px;
                    height: 38px;
                    object-fit: cover;
                    border-radius: 12px;
                }

            .profile-copy strong {
                display: block;
                font-size: 0.9rem;
                line-height: 1.2;
            }

            .profile-copy span {
                display: block;
                color: var(--muted);
                font-size: 0.75rem;
            }

            .dropdown-dark {
                min-width: 18rem;
                padding: 0.7rem;
                border-radius: 18px;
                background: rgba(9, 16, 29, 0.98);
                border: 1px solid rgba(148, 163, 184, 0.14);
                box-shadow: var(--shadow-md);
            }

                .dropdown-dark .dropdown-item {
                    border-radius: 12px;
                    padding: 0.8rem 0.9rem;
                    color: rgba(237, 244, 255, 0.86);
                    transition: background var(--transition), color var(--transition);
                }

                    .dropdown-dark .dropdown-item:hover,
                    .dropdown-dark .dropdown-item.active {
                        background: rgba(57, 219, 200, 0.12);
                        color: #fff;
                    }

            .dropdown-note {
                display: block;
                margin-top: 0.18rem;
                color: rgba(148, 163, 184, 0.84);
                font-size: 0.75rem;
            }

            .content {
                padding: 1.35rem 1.4rem 2rem;
                overflow: visible;
            }

            .content-inner {
                max-width: 1580px;
                margin: 0 auto;
            }

            /* Hero */
            .hero {
                display: grid;
                grid-template-columns: minmax(0, 1.55fr) minmax(320px, 0.9fr);
                gap: 1.2rem;
                align-items: stretch;
                padding: 1.7rem;
                margin-bottom: 1.5rem;
                position: relative;
                overflow: hidden;
            }

                .hero::after {
                    content: "";
                    position: absolute;
                    top: -40px;
                    right: -50px;
                    width: 240px;
                    height: 240px;
                    background: radial-gradient(circle, rgba(255, 183, 93, 0.16), transparent 66%);
                    pointer-events: none;
                }

            .hero-breadcrumb {
                display: inline-flex;
                align-items: center;
                gap: 0.45rem;
                margin-bottom: 0.8rem;
                color: var(--accent);
                font-size: 0.74rem;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.14em;
            }

            .hero h1 {
                margin: 0;
                max-width: 740px;
                font-size: clamp(2rem, 4vw, 3.1rem);
                font-weight: 800;
                line-height: 1.08;
                letter-spacing: -0.03em;
            }

            .hero p {
                margin: 0.95rem 0 0;
                max-width: 690px;
                color: rgba(237, 244, 255, 0.72);
                font-size: 1rem;
                line-height: 1.75;
            }

            .hero-stats {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 0.9rem;
                align-self: stretch;
            }

            .hero-stat {
                position: relative;
                padding: 1rem 1.05rem;
                border-radius: 20px;
                background: rgba(148, 163, 184, 0.08);
                border: 1px solid rgba(148, 163, 184, 0.10);
                overflow: hidden;
                min-height: 112px;
            }

                .hero-stat::before {
                    content: "";
                    position: absolute;
                    right: -40px;
                    bottom: -55px;
                    width: 120px;
                    height: 120px;
                    background: radial-gradient(circle, rgba(57, 219, 200, 0.16), transparent 72%);
                    pointer-events: none;
                }

                .hero-stat span {
                    display: block;
                    color: rgba(237, 244, 255, 0.72);
                    font-size: 0.78rem;
                    letter-spacing: 0.10em;
                    text-transform: uppercase;
                }

                .hero-stat strong {
                    display: block;
                    margin-top: 0.45rem;
                    font-size: 1.5rem;
                    font-weight: 800;
                }

            /* Metrics */
            .metric-card {
                height: 100%;
                padding: 1.2rem;
            }

            .metric-head {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
                margin-bottom: 1rem;
            }

            .metric-card span {
                display: block;
                color: var(--muted);
                font-size: 0.82rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.10em;
            }

            .metric-card strong {
                display: block;
                margin-top: 0.35rem;
                font-size: 1.8rem;
                font-weight: 800;
                letter-spacing: -0.04em;
            }

            .metric-card p {
                margin: 0;
                color: rgba(237, 244, 255, 0.7);
                font-size: 0.88rem;
            }

            .metric-icon {
                width: 48px;
                height: 48px;
                border-radius: 16px;
                display: grid;
                place-items: center;
                font-size: 1.1rem;
                color: #fff;
                background: linear-gradient(135deg, rgba(57, 219, 200, 0.82), rgba(18, 184, 167, 0.78));
            }

            /* Toolbar */
            .toolbar {
                position: relative;
                z-index: 200;
                isolation: isolate;
                overflow: visible;
                padding: 1.4rem;
                margin: 1.5rem 0;
            }

                .toolbar .row {
                    overflow: visible;
                }

                .toolbar .dropdown {
                    position: relative;
                    z-index: 300;
                }

                .toolbar .dropdown-menu {
                    position: absolute !important;
                    top: calc(100% + 12px) !important;
                    left: 0 !important;
                    right: auto !important;
                    inset: auto auto auto 0 !important;
                    transform: none !important;
                    min-width: 100%;
                    z-index: 5000 !important;
                }

            .section-title {
                margin: 0;
                font-size: 1.24rem;
                font-weight: 800;
            }

            .section-subtitle {
                margin: 0.45rem 0 0;
                color: rgba(237, 244, 255, 0.68);
                font-size: 0.94rem;
            }

            .search-box {
                display: flex;
                align-items: center;
                gap: 0.8rem;
                padding: 0.95rem 1rem;
                border-radius: 18px;
                background: rgba(148, 163, 184, 0.08);
                border: 1px solid rgba(148, 163, 184, 0.12);
                height: 100%;
            }

            .btn-accent,
            .btn-filter,
            .btn-soft,
            .btn-danger-soft {
                border-radius: 15px;
                font-weight: 700;
                transition: transform var(--transition), box-shadow var(--transition), background var(--transition), border-color var(--transition);
            }

            .btn-accent {
                color: #041016;
                background: linear-gradient(135deg, var(--accent), #74f1d8);
                border: 0;
                box-shadow: 0 14px 32px rgba(57, 219, 200, 0.22);
            }

                .btn-accent:hover {
                    color: #041016;
                    transform: translateY(-2px);
                    box-shadow: 0 18px 36px rgba(57, 219, 200, 0.28);
                }

            .btn-filter {
                width: 100%;
                padding: 0.85rem 1rem;
                background: rgba(148, 163, 184, 0.08);
                border: 1px solid rgba(148, 163, 184, 0.16);
                color: var(--text);
            }

            .result-pill {
                width: 100%;
                min-height: 100%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 0.45rem;
                padding: 0.85rem 1rem;
                border-radius: 18px;
                background: rgba(57, 219, 200, 0.12);
                border: 1px solid rgba(57, 219, 200, 0.18);
                color: #d9fffa;
                font-size: 0.92rem;
                font-weight: 700;
            }

            /* Vehicle Grid */
            #vehicleGrid {
                position: relative;
                z-index: 1;
            }

            .vehicle-card {
                position: relative;
                z-index: 1;
                height: 100%;
                overflow: hidden;
                transition: transform var(--transition), box-shadow var(--transition), background var(--transition), border-color var(--transition);
            }

                .vehicle-card:hover {
                    z-index: 2;
                    transform: translateY(-10px);
                    box-shadow: var(--shadow-lg);
                    border-color: rgba(57, 219, 200, 0.24);
                    background: linear-gradient(180deg, rgba(18, 29, 48, 0.98), rgba(10, 18, 31, 0.95));
                }

            .vehicle-media {
                position: relative;
                aspect-ratio: 16 / 10;
                overflow: hidden;
                border-radius: 22px 22px 0 0;
            }

                .vehicle-media img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    transition: transform 0.75s ease, filter 0.75s ease;
                }

            .vehicle-card:hover .vehicle-media img {
                transform: scale(1.08) rotate(-1deg);
                filter: saturate(1.08);
            }

            .vehicle-overlay {
                position: absolute;
                inset: 0;
                background: linear-gradient(180deg, rgba(6, 12, 22, 0.06), transparent 38%), linear-gradient(180deg, transparent 36%, rgba(5, 12, 22, 0.88) 100%);
                pointer-events: none;
            }

            .vehicle-status,
            .vehicle-segment {
                position: absolute;
                top: 1rem;
                display: inline-flex;
                align-items: center;
                gap: 0.35rem;
                padding: 0.48rem 0.75rem;
                border-radius: 999px;
                font-size: 0.74rem;
                font-weight: 800;
                letter-spacing: 0.04em;
                backdrop-filter: blur(14px);
                z-index: 2;
            }

            .vehicle-status {
                left: 1rem;
            }

            .vehicle-segment {
                right: 1rem;
                color: #fff;
                background: rgba(10, 18, 31, 0.44);
                border: 1px solid rgba(255, 255, 255, 0.12);
            }

            .status-available {
                background: rgba(70, 221, 150, 0.92);
                color: #06110d;
            }

            .status-rented {
                background: rgba(246, 185, 82, 0.92);
                color: #081018;
            }

            .status-service {
                background: rgba(255, 112, 112, 0.82);
                color: #fff;
            }

            .vehicle-body {
                padding: 1.3rem;
            }

            .vehicle-brand {
                margin: 0 0 0.2rem;
                color: var(--accent);
                font-size: 0.8rem;
                font-weight: 800;
                letter-spacing: 0.12em;
                text-transform: uppercase;
            }

            .vehicle-model {
                margin: 0;
                font-size: 1.35rem;
                font-weight: 800;
                letter-spacing: -0.03em;
            }

            .vehicle-price {
                text-align: right;
            }

                .vehicle-price strong {
                    display: block;
                    font-size: 1.46rem;
                    font-weight: 800;
                    white-space: nowrap;
                }

                .vehicle-price span {
                    color: var(--muted);
                    font-size: 0.8rem;
                    font-weight: 700;
                }

            .vehicle-meta {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                flex-wrap: wrap;
                margin-top: 0.85rem;
                color: rgba(237, 244, 255, 0.72);
                font-size: 0.88rem;
            }

                .vehicle-meta i {
                    color: var(--accent-2);
                }

            .spec-grid {
                display: grid;
                grid-template-columns: repeat(3, minmax(0, 1fr));
                gap: 0.8rem;
                margin: 1.1rem 0 1.05rem;
            }

            .spec-item {
                padding: 0.82rem 0.78rem;
                border-radius: 16px;
                background: rgba(148, 163, 184, 0.06);
                border: 1px solid rgba(148, 163, 184, 0.08);
            }

                .spec-item span {
                    display: block;
                    margin-bottom: 0.35rem;
                    color: var(--muted);
                    font-size: 0.72rem;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 0.08em;
