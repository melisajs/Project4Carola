        },
        {
        brand: "Renault",
        model: "Clio",
        year: 2023,
        fuel: "Benzin",
        transmission: "Manuel",
        price: 1890,
        seats: 5,
        luggage: "391 L",
        branch: "Ümraniye Şubesi",
        status: "Aktif Kirada",
        statusClass: "rented",
        segment: "city",
        segmentLabel: "Compact",
        image: "https://images.unsplash.com/photo-1489824904134-891ab64532f1?auto=format&fit=crop&w=1200&q=80",
        accent: "#54dcff",
        secondary: "#fe7ca5"
        },
        {
        brand: "Peugeot",
        model: "3008",
        year: 2024,
        fuel: "Dizel",
        transmission: "Otomatik",
        price: 3680,
        seats: 5,
        luggage: "520 L",
        branch: "Sarıyer Şubesi",
        status: "Müsait",
        statusClass: "available",
        segment: "suv",
        segmentLabel: "Crossover SUV",
        image: "https://images.unsplash.com/photo-1503736334956-4c8f8e92946d?auto=format&fit=crop&w=1200&q=80",
        accent: "#74e2ff",
        secondary: "#ffbc61"
        }
        ];

        const state = {
        search: "",
        filter: "all"
        };

        const el = {
        grid: document.getElementById("vehicleGrid"),
        searchInput: document.getElementById("searchInput"),
        filterButton: document.getElementById("filterButton"),
        filterOptions: document.querySelectorAll(".filter-option"),
        vehicleCount: document.getElementById("vehicleCount"),
        totalVehicles: document.getElementById("totalVehicles"),
        availableVehicles: document.getElementById("availableVehicles"),
        premiumVehicles: document.getElementById("premiumVehicles"),
        averagePrice: document.getElementById("averagePrice"),
        toastMessage: document.getElementById("toastMessage"),
        vehicleForm: document.getElementById("vehicleForm"),
        desktopSidebarToggle: document.getElementById("desktopSidebarToggle"),
        mobileSidebarToggle: document.getElementById("mobileSidebarToggle"),
        sidebarBackdrop: document.getElementById("sidebarBackdrop")
        };

        const toast = new bootstrap.Toast(document.getElementById("actionToast"));
        const priceFormatter = new Intl.NumberFormat("tr-TR");

        function createFallbackSvg(label, accent, secondary) {
        const safeLabel = label.replace(/&/g, "&amp;");
        const svg = `
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 750">
        <defs>
        <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#09101b"/>
        <stop offset="45%" stop-color="#0d1729"/>
        <stop offset="100%" stop-color="#121f34"/>
        </linearGradient>
        <linearGradient id="acc" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="${accent}"/>
        <stop offset="100%" stop-color="${secondary}"/>
        </linearGradient>
        </defs>
        <rect width="1200" height="750" rx="44" fill="url(#bg)"/>
        <circle cx="1040" cy="130" r="180" fill="${accent}" opacity="0.12"/>
        <circle cx="180" cy="660" r="220" fill="${secondary}" opacity="0.10"/>
        <path d="M240 454 C286 372 392 327 540 327 H702 C784 327 851 356 898 412 L972 425 C1005 430 1029 458 1029 492 V512 H1001 C996 567 951 612 897 612 C842 612 795 567 791 512 H432 C426 567 379 612 324 612 C270 612 222 567 218 512 H181 V487 C181 461 198 438 223 429 L240 454 Z" fill="url(#acc)"/>
        <path d="M333 351 H699 C761 351 818 381 857 431 H292 C300 401 313 375 333 351 Z" fill="#e9f4ff" opacity="0.16"/>
        <circle cx="325" cy="514" r="68" fill="#08111f"/>
        <circle cx="325" cy="514" r="34" fill="#d9f7f6" opacity="0.75"/>
        <circle cx="896" cy="514" r="68" fill="#08111f"/>
        <circle cx="896" cy="514" r="34" fill="#d9f7f6" opacity="0.75"/>
        <text x="88" y="122" fill="#ecf4ff" font-size="42" font-family="Arial, sans-serif" font-weight="700">Carola</text>
        <text x="88" y="182" fill="#9fb0c8" font-size="30" font-family="Arial, sans-serif">${safeLabel}</text>
        </svg>
        `;
        return `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(svg)}`;
        }

        window.vehicleImageFallback = function (img, label, accent, secondary) {
        img.onerror = null;
        img.src = createFallbackSvg(label, accent, secondary);
        };

        function getFilterLabel(filter) {
        const labels = {
        all: "Tüm Araçlar",
        premium: "Premium Segment",
        sedan: "Sedan Araçlar",
        suv: "SUV Araçlar",
        city: "Şehir İçi Ekonomik"
        };
        return labels[filter] || labels.all;
        }

        function filterVehicles() {
        return vehicles.filter(vehicle => {
        const text = `${vehicle.brand} ${vehicle.model} ${vehicle.fuel} ${vehicle.branch} ${vehicle.segmentLabel}`.toLowerCase();
        const matchesSearch = text.includes(state.search.toLowerCase());
        const matchesFilter = state.filter === "all" || vehicle.segment === state.filter;
        return matchesSearch && matchesFilter;
        });
        }

        function renderStats() {
        const total = vehicles.length;
        const available = vehicles.filter(v => v.statusClass === "available").length;
        const premium = vehicles.filter(v => v.segment === "premium").length;
        const average = Math.round(vehicles.reduce((sum, v) => sum + v.price, 0) / total);

        el.totalVehicles.textContent = total;
        el.availableVehicles.textContent = available;
        el.premiumVehicles.textContent = premium;
        el.averagePrice.textContent = `₺${priceFormatter.format(average)}`;
        }

        function renderVehicles() {
        const filtered = filterVehicles();

        el.vehicleCount.textContent = `${filtered.length} araç`;
        el.filterButton.textContent = `Filtre: ${getFilterLabel(state.filter)}`;

        if (!filtered.length) {
        el.grid.innerHTML = `
        <div class="col-12">
        <div class="glass empty-state">
        <div class="empty-icon">
        <i class="bi bi-search"></i>
        </div>
        <h3>Eşleşen araç bulunamadı</h3>
        <p>Arama kelimesini veya filtre seçimini değiştirerek listeyi yeniden daraltabilirsiniz.</p>
        </div>
        </div>
        `;
        return;
        }

        el.grid.innerHTML = filtered.map(vehicle => {
        const fullName = `${vehicle.brand} ${vehicle.model}`;
        return `
        <div class="col-12 col-md-6 col-xxl-4">
        <article class="vehicle-card glass">
        <div class="vehicle-media">
        <img
        src="${vehicle.image}"
        alt="${fullName}"
        loading="lazy"
        onerror="vehicleImageFallback(this, '${fullName}', '${vehicle.accent}', '${vehicle.secondary}')"
        >
        <div class="vehicle-overlay"></div>
        <span class="vehicle-status status-${vehicle.statusClass}">${vehicle.status}</span>
        <span class="vehicle-segment">${vehicle.segmentLabel}</span>
        </div>

        <div class="vehicle-body">
        <div class="d-flex justify-content-between align-items-start gap-3">
        <div>
        <p class="vehicle-brand">${vehicle.brand}</p>
        <h3 class="vehicle-model">${vehicle.model}</h3>
        </div>
        <div class="vehicle-price">
        <strong>₺${priceFormatter.format(vehicle.price)}</strong>
        <span>/ günlük</span>
        </div>
        </div>

        <div class="vehicle-meta">
        <span><i class="bi bi-calendar-event"></i> ${vehicle.year} model</span>
        <span><i class="bi bi-geo-alt"></i> ${vehicle.branch}</span>
        </div>

        <div class="spec-grid">
        <div class="spec-item">
        <span>Yakıt</span>
        <strong>${vehicle.fuel}</strong>
        </div>
        <div class="spec-item">
        <span>Vites</span>
        <strong>${vehicle.transmission}</strong>
        </div>
        <div class="spec-item">
        <span>Koltuk</span>
        <strong>${vehicle.seats} Kişi</strong>
        </div>
        <div class="spec-item">
        <span>Bagaj</span>
        <strong>${vehicle.luggage}</strong>
        </div>
        <div class="spec-item">
        <span>Segment</span>
        <strong>${vehicle.segmentLabel}</strong>
        </div>
        <div class="spec-item">
        <span>Durum</span>
        <strong>${vehicle.status}</strong>
        </div>
        </div>

        <div class="vehicle-footer">
        <div class="branch-info">
        <i class="bi bi-shield-check"></i>
        Operasyon: ${vehicle.branch}
        </div>

        <div class="action-group">
        <button class="btn btn-soft" type="button" data-action="detail" data-name="${fullName}">Detay Gör</button>
        <button class="btn btn-outline-light" type="button" data-action="edit" data-name="${fullName}">Düzenle</button>
        <button class="btn btn-danger-soft" type="button" data-action="delete" data-name="${fullName}">Sil</button>
        </div>
        </div>
        </div>
        </article>
        </div>
        `;
        }).join("");
        }

        function showToast(message) {
        el.toastMessage.textContent = message;
        toast.show();
        }

        function toggleSidebar() {
        if (window.innerWidth < 992) {
        document.body.classList.toggle("sidebar-mobile-open");
        return;
        }
        document.body.classList.toggle("sidebar-collapsed");
        }

        function closeMobileSidebar() {
        document.body.classList.remove("sidebar-mobile-open");
        }

        el.searchInput.addEventListener("input", e => {
        state.search = e.target.value.trim();
        renderVehicles();
        });

        el.filterOptions.forEach(option => {
        option.addEventListener("click", () => {
        state.filter = option.dataset.filter;
        el.filterOptions.forEach(item => item.classList.remove("active"));
        option.classList.add("active");
        renderVehicles();
        });
        });

        el.desktopSidebarToggle.addEventListener("click", toggleSidebar);
        el.mobileSidebarToggle.addEventListener("click", toggleSidebar);
        el.sidebarBackdrop.addEventListener("click", closeMobileSidebar);

        window.addEventListener("resize", () => {
        if (window.innerWidth >= 992) {
        closeMobileSidebar();
        }
        });

        document.addEventListener("click", e => {
        const actionButton = e.target.closest("[data-action]");
        if (!actionButton) return;

        const action = actionButton.dataset.action;
        const name = actionButton.dataset.name;

        const messages = {
        detail: `${name} için detay görünümü hazır.`,
        edit: `${name} için düzenleme işlemi tetiklendi.`,
        delete: `${name} için silme onayı hazırlandı.`
        };

        showToast(messages[action] || "İşlem tamamlandı.");
        });

        el.vehicleForm.addEventListener("submit", e => {
        e.preventDefault();
        const modal = bootstrap.Modal.getInstance(document.getElementById("addVehicleModal"));
        modal.hide();
        showToast("Yeni araç kaydı başarıyla oluşturuldu.");
        el.vehicleForm.reset();
        });

        renderStats();
        renderVehicles();
    </script>
</body>
</html>