@model List<CarolaEnditiyLayer.Entities.Category>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kategori Yönetimi";
}

<section class="hero glass text-start">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <span class="hero-breadcrumb">
                <i class="bi bi-folder-fill"></i>
                Filo Yönetimi / Kategoriler
            </span>
            <h1>Araç kategorilerini ve sınıflandırmalarını yönetin</h1>
            <p>Filodaki araçların sınıflandırma başlıklarını buradan güncelleyebilirsiniz.</p>
        </div>
        <button class="btn btn-accent px-4 py-2" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
            <i class="bi bi-plus-lg"></i> Yeni Kategori Ekle
        </button>
    </div>
</section>

<!-- Categories List Table -->
<div class="card glass p-4 border-0 text-start">
    <h3 class="fs-5 font-weight-bold mb-4" style="color: #fff;"><i class="bi bi-list-nested text-primary"></i> Kategori Listesi</h3>

    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Kategori ID</th>
                    <th>Kategori Adı</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || Model.Count == 0)
                {
                    <tr>
                        <td colspan="3" class="text-center py-4 text-muted">Kayıtlı kategori bulunmamaktadır.</td>
                    </tr>
                }
                else
                {
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td><strong>#@cat.CarCategoryId</strong></td>
                            <td><strong class="text-white">@cat.CategoryName</strong></td>
                            <td class="text-end">
                                <button class="btn btn-outline-light btn-sm me-2 edit-cat-btn" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#editCategoryModal"
                                        data-id="@cat.CarCategoryId"
                                        data-name="@cat.CategoryName">
                                    Düzenle
                                </button>
                                <a href="@Url.Action("Delete", "AdminCategory", new { id = cat.CarCategoryId })" class="btn btn-danger-soft btn-sm" onclick="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?')">Sil</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Category Modal -->
<div class="modal fade" id="addCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass border border-secondary border-opacity-25" style="background-color: var(--bg-2);">
            <div class="modal-header border-bottom border-secondary border-opacity-25 px-4">
                <h5 class="modal-title font-weight-bold text-white">Yeni Kategori Ekle</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="POST" action="@Url.Action("Create", "AdminCategory")">
                <div class="modal-body p-4 text-start">
                    <div class="mb-3">
                        <label class="form-label">Kategori Adı *</label>
                        <input type="text" name="CategoryName" class="form-control" placeholder="Örn: SUV" required />
                    </div>
                </div>
                <div class="modal-footer border-top border-secondary border-opacity-25 px-4">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-accent">Kategori Ekle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Category Modal -->
<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass border border-secondary border-opacity-25" style="background-color: var(--bg-2);">
            <div class="modal-header border-bottom border-secondary border-opacity-25 px-4">
                <h5 class="modal-title font-weight-bold text-white">Kategori Düzenle</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="POST" action="@Url.Action("Edit", "AdminCategory")">
                <input type="hidden" name="CarCategoryId" id="editCategoryId" />
                <div class="modal-body p-4 text-start">
                    <div class="mb-3">
                        <label class="form-label">Kategori Adı *</label>
                        <input type="text" name="CategoryName" id="editCategoryName" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer border-top border-secondary border-opacity-25 px-4">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-accent">Değişiklikleri Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const editCatBtns = document.querySelectorAll('.edit-cat-btn');
        editCatBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                document.getElementById('editCategoryId').value = btn.dataset.id;
                document.getElementById('editCategoryName').value = btn.dataset.name;
            });
        });
    </script>
}
