@{
    Layout = null;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var encodedReturnUrl = System.Uri.EscapeDataString(returnUrl);
    var isEnglish = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en";
}
<!DOCTYPE html>
<html lang="@(isEnglish ? "en" : "tr")">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Carola | Admin Panel</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>
            :root {
                --bg: #070817;
                --bg-2: #10152d;
                --panel: rgba(20, 24, 52, 0.86);
                --panel-2: rgba(12, 16, 38, 0.97);
                --line: rgba(159, 171, 255, 0.14);
                --line-strong: rgba(159, 171, 255, 0.28);
                --text: #f4f6ff;
                --muted: #9aa5c8;
                --accent: #7386ff;
                --accent-hover: #5c70f5;
                --accent-2: #29d3d0;
                --success: #3ee6a3;
                --warning: #ffc766;
                --danger: #ff7189;
                --sidebar-width: 292px;
                --sidebar-mini: 92px;
                --topbar-height: 86px;
                --radius-xl: 28px;
                --radius-lg: 22px;
                --radius-md: 16px;
                --shadow-lg: 0 30px 80px rgba(0, 2, 16, 0.52);
                --shadow-md: 0 18px 48px rgba(0, 2, 18, 0.34);
                --transition: 0.35s ease;
            }

            * {
                box-sizing: border-box;
            }

            body {
                min-height: 100vh;
                font-family: "Manrope", sans-serif;
                color: var(--text);
                background: radial-gradient(circle at 14% 0%, rgba(115, 134, 255, 0.20), transparent 32%), radial-gradient(circle at 96% 92%, rgba(41, 211, 208, 0.13), transparent 30%), linear-gradient(145deg, #050612 0%, #0b0f24 46%, #111630 100%);
                overflow-x: hidden;
            }

            body::before {
                content: "";
                position: fixed;
                inset: 0;
                background-image: linear-gradient(rgba(146,158,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(146,158,255,0.025) 1px, transparent 1px);
                background-size: 56px 56px;
                mask-image: linear-gradient(180deg, rgba(0,0,0,0.65), transparent 94%);
                pointer-events: none;
                z-index: -1;
            }

            a {
                text-decoration: none;
                color: inherit;
            }

            .glass {
                background: linear-gradient(160deg, rgba(25, 30, 65, 0.90), rgba(12, 16, 39, 0.96));
                border: 1px solid var(--line);
                border-radius: var(--radius-lg);
                box-shadow: var(--shadow-md);
                backdrop-filter: blur(18px);
            }

            .app-shell {
                display: flex;
                min-height: 100vh;
            }

            /* Sidebar */
            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                z-index: 1100;
                width: var(--sidebar-width);
                height: 100vh;
                padding: 1.2rem 1rem;
                background: linear-gradient(180deg, rgba(10, 12, 31, 0.98), rgba(13, 18, 43, 0.97));
                border-right: 1px solid rgba(130, 145, 255, 0.16);
                backdrop-filter: blur(24px);
                box-shadow: 26px 0 70px rgba(0, 2, 18, 0.42);
                display: flex;
                flex-direction: column;
                transition: width var(--transition), transform var(--transition), padding var(--transition);
            }

            .sidebar-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 0.75rem;
                margin-bottom: 1.4rem;
            }

            .brand {
                display: flex;
                align-items: center;
                gap: 0.9rem;
                min-width: 0;
            }

            .brand-mark {
                width: 52px;
                height: 52px;
                border-radius: 18px;
                display: grid;
                place-items: center;
                background: linear-gradient(135deg, #7082ff, #30d1ce);
                border: 1px solid rgba(255,255,255,0.18);
                color: #070817;
                box-shadow: 0 12px 30px rgba(92,112,245,.28);
                font-size: 1.35rem;
                flex-shrink: 0;
            }

            .brand-copy {
                min-width: 0;
                transition: opacity var(--transition), transform var(--transition);
            }

            .brand-copy strong {
                display: block;
                font-size: 1rem;
                font-weight: 800;
                letter-spacing: 0.02em;
            }

            .brand-copy span {
                display: block;
                color: var(--muted);
                font-size: 0.77rem;
                letter-spacing: 0.12em;
                text-transform: uppercase;
            }

            .sidebar-scroll {
                display: flex;
                flex-direction: column;
                gap: 1.2rem;
                overflow-y: auto;
                padding-right: 0.2rem;
                flex-grow: 1;
            }

            .sidebar-scroll::-webkit-scrollbar {
                width: 8px;
            }

            .sidebar-scroll::-webkit-scrollbar-thumb {
                background: rgba(148, 163, 184, 0.12);
                border-radius: 999px;
            }

            .nav-title {
                margin: 0 0 0.55rem;
                padding-left: 0.9rem;
                color: rgba(237, 244, 255, 0.46);
                font-size: 0.72rem;
                font-weight: 800;
                letter-spacing: 0.14em;
                text-transform: uppercase;
            }

            .menu-link,
            .menu-toggle,
            .submenu-link {
                width: 100%;
                display: flex;
                align-items: center;
                gap: 0.9rem;
                padding: 0.9rem 1rem;
                border-radius: 16px;
                border: 0;
                background: transparent;
                color: rgba(237, 244, 255, 0.82);
                font-weight: 600;
                transition: transform var(--transition), background var(--transition), border-color var(--transition), color var(--transition);
                text-align: left;
            }

            .menu-link:hover,
            .menu-toggle:hover,
            .submenu-link:hover {
                color: #fff;
                background: rgba(148, 163, 184, 0.08);
                transform: translateX(4px);
            }

            .menu-link.active,
            .menu-toggle.active,
            .submenu-link.active {
                color: #fff;
                background: linear-gradient(135deg, rgba(115, 134, 255, 0.24), rgba(41, 211, 208, 0.08));
                border: 1px solid rgba(115, 134, 255, 0.30);
                box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
            }

            .menu-link i,
            .menu-toggle i:first-child {
                font-size: 1.05rem;
                flex-shrink: 0;
            }

            .menu-label {
                flex: 1;
                text-align: left;
                white-space: nowrap;
                transition: opacity var(--transition), transform var(--transition);
            }

            .menu-arrow {
                font-size: 0.82rem;
                transition: transform var(--transition), opacity var(--transition);
            }

            .menu-toggle[aria-expanded="true"] .menu-arrow {
                transform: rotate(180deg);
            }

            .submenu {
                padding: 0.35rem 0 0.15rem 2.2rem;
                transition: opacity var(--transition), transform var(--transition);
            }

            .submenu-link {
                font-size: 0.94rem;
                padding: 0.72rem 0.92rem;
                color: rgba(237, 244, 255, 0.68);
                position: relative;
            }

            .submenu-link::before {
                content: "";
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: var(--accent-2);
                box-shadow: 0 0 12px rgba(41,211,208,.55);
                margin-right: 0.15rem;
                flex-shrink: 0;
            }

            /* Main Panel */
            .main-panel {
                margin-left: var(--sidebar-width);
                flex: 1;
                min-width: 0;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                transition: margin-left var(--transition);
            }

            /* Topbar */
            .topbar {
                height: var(--topbar-height);
                padding: 0 2rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 2rem;
                border-bottom: 1px solid rgba(136, 150, 255, 0.13);
                background: rgba(7, 9, 24, 0.70);
                backdrop-filter: blur(20px);
                position: sticky;
                top: 0;
                z-index: 1000;
            }

            .icon-btn {
                width: 44px;
                height: 44px;
                border-radius: 14px;
                border: 1px solid var(--line);
                background: rgba(25, 31, 67, 0.68);
                color: var(--text);
                display: grid;
                place-items: center;
                font-size: 1.1rem;
                cursor: pointer;
                transition: var(--transition);
            }

            .icon-btn:hover {
                background: rgba(36, 44, 91, 0.84);
                border-color: var(--line-strong);
                color: #fff;
            }

            .topbar-right {
                display: flex;
                align-items: center;
                gap: 1rem;
            }

            .user-profile {
                display: flex;
                align-items: center;
                gap: 0.85rem;
                padding: 0.45rem 1rem 0.45rem 0.55rem;
                border-radius: 18px;
                border: 1px solid var(--line);
                background: rgba(25, 31, 67, 0.62);
                cursor: pointer;
                transition: var(--transition);
            }

            .user-profile:hover {
                background: rgba(36, 44, 91, 0.84);
                border-color: var(--line-strong);
            }

            .user-avatar {
                width: 38px;
                height: 38px;
                border-radius: 12px;
                background: linear-gradient(135deg, var(--accent), var(--accent-2));
                display: grid;
                place-items: center;
                font-weight: 800;
                color: #070817;
            }

            .user-info {
                text-align: left;
            }

            .user-info strong {
                display: block;
                font-size: 0.88rem;
                line-height: 1.2;
            }

            .user-info span {
                display: block;
                font-size: 0.72rem;
                color: var(--muted);
            }

            /* Content Area */
            .content {
                flex: 1;
                padding: 2.2rem 2rem;
            }

            .topbar-context { display:flex; flex-direction:column; gap:.15rem; }
            .topbar-kicker { color:var(--accent-2); font-size:.68rem; font-weight:800; letter-spacing:.14em; text-transform:uppercase; }
            .topbar-title { color:#fff; font-size:1rem; font-weight:800; }
            .topbar-actions { display:flex; align-items:center; gap:.7rem; }
            .status-pill { display:inline-flex; align-items:center; gap:.5rem; padding:.58rem .9rem; border:1px solid var(--line); border-radius:14px; color:var(--muted); font-size:.76rem; font-weight:700; background:rgba(25,31,67,.48); }
            .status-pill::before { content:""; width:7px; height:7px; border-radius:50%; background:var(--success); box-shadow:0 0 12px var(--success); }
            .site-preview-btn { display:inline-flex; align-items:center; gap:.5rem; padding:.62rem .9rem; border-radius:14px; color:#fff; font-size:.78rem; font-weight:750; border:1px solid rgba(115,134,255,.27); background:linear-gradient(135deg,rgba(115,134,255,.22),rgba(41,211,208,.08)); }
            .site-preview-btn:hover { color:#fff; transform:translateY(-2px); border-color:rgba(41,211,208,.45); }

            .content-inner {
                max-width: 1400px;
                margin: 0 auto;
                display: flex;
                flex-direction: column;
                gap: 2.2rem;
            }

            /* Dashboard Cards & Layout */
            .hero {
                padding: 2.4rem 2.8rem;
                display: flex;
                flex-direction: column;
                gap: 1.8rem;
                position: relative;
                overflow: hidden;
            }
            .hero::after { content:""; position:absolute; width:260px; height:260px; border:48px solid rgba(115,134,255,.07); border-radius:50%; right:-85px; top:-110px; pointer-events:none; }

            .hero h1 {
                font-size: 1.85rem;
                font-weight: 800;
                margin: 0 0 0.65rem;
                line-height: 1.3;
                background: linear-gradient(135deg, #fff 30%, var(--muted) 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .hero p {
                margin: 0;
                color: var(--muted);
                font-size: 0.98rem;
                line-height: 1.6;
                max-width: 680px;
            }

            .hero-breadcrumb {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                color: var(--accent);
                font-size: 0.75rem;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.12em;
                margin-bottom: 0.85rem;
            }

            .hero-stats {
                display: flex;
                flex-wrap: wrap;
                gap: 1.5rem 3.2rem;
                border-top: 1px solid var(--line);
                padding-top: 1.6rem;
            }

            .hero-stat {
                display: flex;
                flex-direction: column;
                gap: 0.25rem;
            }

            .hero-stat span {
                color: var(--muted);
                font-size: 0.77rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.08em;
            }

            .hero-stat strong {
                font-size: 1.45rem;
                font-weight: 800;
                color: #fff;
            }

            /* Metric Cards */
            .metric-card {
                padding: 1.8rem;
                height: 100%;
                display: flex;
                flex-direction: column;
                gap: 0.95rem;
            }

            .metric-head {
                display: flex;
                align-items: flex-start;
                justify-content: space-between;
                gap: 1rem;
            }

            .metric-head span {
                display: block;
                color: var(--muted);
                font-size: 0.82rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                margin-bottom: 0.25rem;
            }

            .metric-head strong {
                font-size: 1.85rem;
                font-weight: 800;
                color: #fff;
            }

            .metric-icon {
                width: 48px;
                height: 48px;
                border-radius: 14px;
                background: linear-gradient(135deg, rgba(115,134,255,.16), rgba(41,211,208,.08));
                border: 1px solid var(--line);
                color: var(--accent);
                display: grid;
                place-items: center;
                font-size: 1.25rem;
            }

            .metric-card p {
                margin: 0;
                color: var(--muted);
                font-size: 0.85rem;
                line-height: 1.5;
            }

            /* Tables in Admin */
            .admin-table {
                width: 100%;
                border-collapse: collapse;
                color: var(--text);
                font-size: 0.92rem;
            }

            .admin-table th {
                background: rgba(20, 26, 59, 0.72);
                border-bottom: 2px solid var(--line-strong);
                padding: 1rem 1.2rem;
                font-weight: 700;
                color: var(--muted);
                text-transform: uppercase;
                font-size: 0.76rem;
                letter-spacing: 0.08em;
            }

            .admin-table td {
                padding: 1.1rem 1.2rem;
                border-bottom: 1px solid var(--line);
                vertical-align: middle;
            }

            .admin-table tr:hover td {
                background: rgba(115, 134, 255, 0.06);
            }

            /* Form Elements */
            .form-label {
                color: var(--muted);
                font-weight: 700;
                font-size: 0.82rem;
                text-transform: uppercase;
                letter-spacing: 0.08em;
            }

            .form-control,
            .form-select {
                background: rgba(20, 26, 59, 0.68);
                border: 1px solid var(--line);
                color: var(--text);
                border-radius: 12px;
                padding: 0.75rem 1rem;
                font-size: 0.92rem;
                transition: var(--transition);
            }

            .form-control:focus,
            .form-select:focus {
                background: rgba(31, 39, 80, 0.88);
                border-color: var(--accent);
                color: #fff;
                box-shadow: 0 0 0 3px rgba(115, 134, 255, 0.18);
            }

            .btn-accent {
                background-color: var(--accent);
                border-color: var(--accent);
                color: #fff;
                font-weight: 700;
                border-radius: 12px;
                padding: 0.75rem 1.5rem;
                transition: var(--transition);
            }

            .btn-accent:hover {
                background-color: var(--accent-hover);
                border-color: var(--accent-hover);
                color: #fff;
                transform: translateY(-2px);
            }

            .text-primary { color: var(--accent) !important; }
            .bg-primary { background-color: var(--accent) !important; }
            .btn-primary { background: linear-gradient(135deg,var(--accent),#596bf0); border-color:transparent; }
            .btn-primary:hover { background: linear-gradient(135deg,var(--accent-hover),#4658d9); border-color:transparent; }
            .card.glass { transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition); }
            .card.glass:hover { transform:translateY(-3px); border-color:rgba(115,134,255,.28); box-shadow:var(--shadow-lg); }

            /* Sidebar toggle mobile */
            .sidebar-backdrop {
                position: fixed;
                inset: 0;
                background: rgba(4, 10, 20, 0.65);
                z-index: 1090;
                opacity: 0;
                pointer-events: none;
                transition: opacity var(--transition);
            }

            @@media (max-width: 991.98px) {
                .sidebar {
                    transform: translateX(-100%);
                }
                .main-panel {
                    margin-left: 0;
                }
                body.sidebar-mobile-open .sidebar {
                    transform: translateX(0);
                }
                body.sidebar-mobile-open .sidebar-backdrop {
                    opacity: 1;
                    pointer-events: auto;
                }
            }

            /* Aurora Carbon — modern admin theme */
            :root {
                --bg: #090d0f;
                --bg-2: #101719;
                --panel: #141c1f;
                --panel-2: #0e1416;
                --line: rgba(169, 239, 214, 0.11);
                --line-strong: rgba(169, 239, 214, 0.22);
                --text: #eff8f4;
                --muted: #82938f;
                --accent: #8ce7bc;
                --accent-hover: #6ed6a7;
                --accent-2: #6aa9ff;
                --success: #63e6ad;
                --warning: #ffd078;
                --danger: #ff7c91;
                --sidebar-width: 272px;
                --topbar-height: 76px;
                --radius-xl: 24px;
                --radius-lg: 18px;
                --radius-md: 13px;
                --shadow-lg: 0 24px 70px rgba(0, 0, 0, 0.38);
                --shadow-md: 0 14px 38px rgba(0, 0, 0, 0.24);
            }
            body {
                font-family:"Manrope",sans-serif;
                background:
                    radial-gradient(circle at 88% -10%,rgba(106,169,255,.12),transparent 30%),
                    radial-gradient(circle at 18% 95%,rgba(140,231,188,.08),transparent 31%),
                    #090d0f;
            }
            body::before {
                opacity:.42;
                background-image:linear-gradient(rgba(171,239,215,.018) 1px,transparent 1px),linear-gradient(90deg,rgba(171,239,215,.018) 1px,transparent 1px);
                background-size:42px 42px;
            }
            h1,h2,h3,h4,h5,h6,.brand-copy strong,.metric-head strong { font-family:"Sora",sans-serif; }
            .sidebar {
                padding:18px 14px;
                background:linear-gradient(180deg,#0d1315 0%,#0a1012 68%,#0c1516 100%);
                border-right:1px solid rgba(169,239,214,.09);
                box-shadow:18px 0 54px rgba(0,0,0,.25);
            }
            .sidebar::after { content:""; position:absolute; inset:0; pointer-events:none; background:radial-gradient(circle at 12% 2%,rgba(140,231,188,.08),transparent 22%); }
            .sidebar>* { position:relative; z-index:1; }
            .sidebar-header { min-height:58px; margin-bottom:18px; padding:0 4px 14px; border-bottom:1px solid var(--line); }
            .brand { gap:11px; }
            .brand-mark {
                width:46px;height:46px;border-radius:14px;
                color:#07110d;
                background:linear-gradient(145deg,#b7f7d7,#65cfa4 58%,#6aa9ff);
                box-shadow:0 10px 26px rgba(88,207,157,.18);
            }
            .brand-copy strong { font-size:1.06rem; letter-spacing:-.025em; }
            .brand-copy span { color:#6e827c; font-size:.61rem; letter-spacing:.17em; }
            .nav-title { margin-top:5px; padding-left:13px; color:#53645f; font-size:.61rem; letter-spacing:.18em; }
            .sidebar-scroll { gap:14px; }
            .menu-link,.menu-toggle,.submenu-link { min-height:44px; gap:12px; padding:11px 13px; border-radius:12px; color:#91a19d; font-size:.84rem; }
            .menu-link i,.menu-toggle i:first-child { width:24px; color:#627873; font-size:1rem; text-align:center; transition:.25s ease; }
            .menu-link:hover,.menu-toggle:hover,.submenu-link:hover { color:#eaf5f1; background:rgba(255,255,255,.035); transform:none; }
            .menu-link:hover i,.menu-toggle:hover i:first-child { color:var(--accent); }
            .menu-link.active,.menu-toggle.active,.submenu-link.active {
                color:#dff9ed;
                background:linear-gradient(90deg,rgba(140,231,188,.14),rgba(106,169,255,.055));
                border:1px solid rgba(140,231,188,.13);
                box-shadow:none;
            }
            .menu-link.active::before,.menu-toggle.active::before { content:""; position:absolute; left:-3px; width:3px; height:23px; border-radius:4px; background:var(--accent); box-shadow:0 0 16px rgba(140,231,188,.45); }
            .menu-link,.menu-toggle { position:relative; }
            .menu-link.active i,.menu-toggle.active i:first-child { color:var(--accent); }
            .submenu { padding-left:28px; }
            .submenu-link { min-height:36px; padding:8px 12px; font-size:.79rem; }
            .submenu-link::before { width:4px;height:4px;background:#61746e;box-shadow:none; }
            .submenu-link.active::before { background:var(--accent);box-shadow:0 0 10px rgba(140,231,188,.45); }
            .sidebar-note { margin-top:10px; padding:17px; border:1px solid rgba(140,231,188,.11); border-radius:16px; background:linear-gradient(145deg,rgba(140,231,188,.07),rgba(106,169,255,.035)); }
            .sidebar-note small { color:var(--accent); font-size:.64rem; font-weight:800; text-transform:uppercase; letter-spacing:.12em; }
            .sidebar-note h4 { margin:9px 0 7px; color:#e7f4ef; font-size:.83rem; line-height:1.45; }
            .sidebar-note p { margin:0; color:#72847f; font-size:.68rem; line-height:1.55; }
            .topbar {
                height:var(--topbar-height);padding:0 28px;
                background:rgba(9,13,15,.82);
                border-bottom:1px solid rgba(169,239,214,.08);
                box-shadow:0 8px 32px rgba(0,0,0,.12);
            }
            .topbar-kicker { color:var(--accent); font-size:.59rem; }
            .topbar-title { font-family:"Sora",sans-serif; font-size:.9rem; }
            .icon-btn,.status-pill,.site-preview-btn,.user-profile { background:#121a1d; border-color:var(--line); }
            .site-preview-btn { color:#b7c8c3; }
            .site-preview-btn:hover { color:#07110d; background:var(--accent); border-color:var(--accent); }
            .status-pill { color:#81928d; }
            .user-avatar { color:#07110d; background:linear-gradient(145deg,var(--accent),#61cda1); border-radius:11px; }
            .content { padding:28px; }
            .content-inner { max-width:1540px; gap:24px; }
            .glass { background:linear-gradient(145deg,rgba(21,29,32,.96),rgba(14,20,22,.98)); border:1px solid var(--line); box-shadow:var(--shadow-md); backdrop-filter:blur(16px); }
            .hero { padding:28px 31px; gap:16px; }
            .hero::after { width:230px;height:230px;right:-75px;top:-110px;border:42px solid rgba(140,231,188,.035); }
            .hero-breadcrumb { color:var(--accent); font-size:.65rem; }
            .hero h1 { max-width:900px; font-size:1.5rem; letter-spacing:-.035em; background:none; -webkit-text-fill-color:initial; color:#eef7f4; }
            .hero p { color:#7e908b; font-size:.84rem; }
            .metric-card { position:relative; overflow:hidden; min-height:150px; padding:22px; gap:13px; }
            .metric-card::after { content:""; position:absolute; inset:auto -30px -40px auto; width:105px;height:105px;border:24px solid rgba(140,231,188,.026);border-radius:50%; }
            .metric-head span { color:#71827e; font-size:.65rem; letter-spacing:.11em; }
            .metric-head strong { font-size:1.65rem; }
            .metric-icon { width:43px;height:43px;border:0;border-radius:13px;color:#09110e;background:linear-gradient(145deg,#aef2d2,#68cfaa); }
            .row>div:nth-child(2)>.metric-card .metric-icon { background:linear-gradient(145deg,#9fd0ff,#6aa9ff); }
            .row>div:nth-child(3)>.metric-card .metric-icon { background:linear-gradient(145deg,#c8b8ff,#9a86ed); }
            .row>div:nth-child(4)>.metric-card .metric-icon { background:linear-gradient(145deg,#ffe1a3,#ffc568); }
            .metric-card p { font-size:.72rem; }
            .card.glass:hover { transform:translateY(-2px); border-color:rgba(140,231,188,.19); box-shadow:var(--shadow-lg); }
            .admin-table th { padding:13px 15px; color:#667873; background:#101719; border-bottom:1px solid var(--line); font-size:.64rem; }
            .admin-table td { padding:14px 15px; border-bottom:1px solid rgba(169,239,214,.065); font-size:.8rem; }
            .admin-table tbody tr:last-child td { border-bottom:0; }
            .admin-table tr:hover td { background:rgba(140,231,188,.025); }
            .admin-thumb { width:68px;height:46px;object-fit:cover;border-radius:11px;background:#0d1416;border:1px solid var(--line); }
            .form-control,.form-select { background:#101719;border-color:var(--line);color:#e8f3ef;border-radius:11px; }
            .form-control:focus,.form-select:focus { background:#131d20;border-color:rgba(140,231,188,.55);box-shadow:0 0 0 3px rgba(140,231,188,.08); }
            .form-select option { color:#e8f3ef;background:#101719; }
            .btn-accent,.btn-primary { color:#07110d;background:linear-gradient(135deg,#a7efcc,#69d1a7);border:0;box-shadow:0 9px 24px rgba(105,209,167,.13); }
            .btn-accent:hover,.btn-primary:hover { color:#07110d;background:linear-gradient(135deg,#baf5d8,#7adcb3); }
            .text-primary { color:var(--accent)!important; }
            .bg-primary { background:var(--accent)!important; }
            .modal-content { background:#11191b!important; }
            .badge { border-radius:999px; padding:.45em .7em; }
            .progress { border-radius:999px; overflow:hidden; }
            .progress-bar.bg-primary { background:linear-gradient(90deg,var(--accent),var(--accent-2))!important; }
            body.sidebar-collapsed .sidebar { width:84px;padding-left:14px;padding-right:14px; }
            body.sidebar-collapsed .main-panel { margin-left:84px; }
            body.sidebar-collapsed .brand-copy,body.sidebar-collapsed .nav-title,body.sidebar-collapsed .menu-label,body.sidebar-collapsed .menu-arrow,body.sidebar-collapsed .submenu,body.sidebar-collapsed .sidebar-note { display:none; }
            body.sidebar-collapsed .sidebar-header { justify-content:center; }
            body.sidebar-collapsed .sidebar-header .icon-btn { display:none!important; }
            body.sidebar-collapsed .menu-link,body.sidebar-collapsed .menu-toggle { justify-content:center;padding:11px; }
            @@media(max-width:767.98px){.content{padding:18px 14px}.topbar{padding:0 14px}.hero{padding:23px 20px}.user-info{display:none}.user-profile{padding:5px}.status-pill{display:none}}
    </style>
</head>
<body>

    <div class="app-shell">
        
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <a asp-controller="Home" asp-action="Index" class="brand">
                    <div class="brand-mark">
                        <i class="bi bi-car-front-fill"></i>
                    </div>
                    <div class="brand-copy">
                        <strong>Carola</strong>
                        <span>@T.Translate("Yönetim Paneli", "Admin Console")</span>
                    </div>
                </a>
                <button class="icon-btn d-none d-lg-inline-grid" id="desktopSidebarToggle" type="button" aria-label="Sidebar daralt">
                    <i class="bi bi-layout-sidebar-inset"></i>
                </button>
            </div>

            <div class="sidebar-scroll">
                <div>
                    <p class="nav-title">@T.Translate("Ana Menü", "Main Menu")</p>
                    <nav class="nav flex-column gap-1">
                        <a asp-controller="AdminDashboard" asp-action="Index" class="menu-link">
                            <i class="bi bi-grid-1x2-fill"></i>
                            <span class="menu-label">@T.Translate("Gösterge Paneli", "Dashboard")</span>
                        </a>

                        <button class="menu-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#vehicleMenu" aria-expanded="true" aria-controls="vehicleMenu">
                            <i class="bi bi-car-front-fill"></i>
                            <span class="menu-label">@T.Translate("Araç Yönetimi", "Fleet Management")</span>
                            <i class="bi bi-chevron-down menu-arrow"></i>
                        </button>
                        <div class="collapse show submenu" id="vehicleMenu">
                            <a asp-controller="AdminCar" asp-action="Index" class="submenu-link">@T.Translate("Araç Listesi", "Vehicle List")</a>
                            <a asp-controller="AdminCategory" asp-action="Index" class="submenu-link">@T.Translate("Kategoriler", "Categories")</a>
                            <a asp-controller="AdminBrand" asp-action="Index" class="submenu-link">@T.Translate("Markalar", "Brands")</a>
                            <a asp-controller="AdminLocation" asp-action="Index" class="submenu-link">@T.Translate("Şubeler", "Branches")</a>
                        </div>

                        <button class="menu-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#reservationMenu" aria-expanded="true" aria-controls="reservationMenu">
                            <i class="bi bi-calendar-check-fill"></i>
                            <span class="menu-label">@T.Translate("Rezervasyonlar", "Reservations")</span>
                            <i class="bi bi-chevron-down menu-arrow"></i>
                        </button>
                        <div class="collapse show submenu" id="reservationMenu">
                            <a asp-controller="AdminReservation" asp-action="Index" class="submenu-link">@T.Translate("Tüm Rezervasyonlar", "All Reservations")</a>
                        </div>

                        <p class="nav-title mt-3">@T.Translate("Site İçeriği", "Site Content")</p>
                        
                        <a asp-controller="AdminSlider" asp-action="Index" class="menu-link">
                            <i class="bi bi-images"></i>
                            <span class="menu-label">@T.Translate("Slider Yönetimi", "Slider Management")</span>
                        </a>

                        <a asp-controller="AdminWeAreTheBest" asp-action="Index" class="menu-link">
                            <i class="bi bi-award-fill"></i>
                            <span class="menu-label">We Are The Best</span>
                        </a>
                        
                        <p class="nav-title mt-3">@T.Translate("Hesap", "Account")</p>
                        <a asp-controller="Home" asp-action="Index" class="menu-link">
                            <i class="bi bi-house-door-fill"></i>
                            <span class="menu-label">@T.Translate("Müşteri Arayüzü", "Customer Site")</span>
                        </a>
                    </nav>
                </div>

                <div class="sidebar-note">
                    <small><i class="bi bi-lightning-charge-fill"></i> @T.Translate("Günlük Özet", "Daily Brief")</small>
                    <h4>@T.Translate("Operasyonu tek ekrandan yönetin", "Run operations from one place")</h4>
                    <p>@T.Translate("Rezervasyon, filo ve içerik akışınız her an kontrol altında.", "Keep reservations, fleet and content under control.")</p>
                </div>
            </div>
        </aside>

        <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

        <!-- Main Panel -->
        <div class="main-panel">
            
            <!-- Topbar -->
            <nav class="topbar">
                <button class="icon-btn d-lg-none" id="mobileSidebarToggle" type="button" aria-label="Mobil sidebar aç">
                    <i class="bi bi-list"></i>
                </button>

                <div class="topbar-context d-none d-md-flex">
                    <span class="topbar-kicker">CAROLA CONTROL</span>
                    <span class="topbar-title">@T.Translate("Operasyon Yönetim Merkezi", "Operations Control Center")</span>
                </div>

                <div class="topbar-right ms-auto">
                    <div class="topbar-actions d-none d-lg-flex">
                        <span class="status-pill">@T.Translate("Sistem Aktif", "System Online")</span>
                        <a class="site-preview-btn" href="/" target="_blank"><i class="bi bi-box-arrow-up-right"></i>@T.Translate("Siteyi Gör", "View Site")</a>
                        <a class="site-preview-btn" href="/Language/Set?culture=@(isEnglish ? "tr-TR" : "en-US")&returnUrl=@encodedReturnUrl"><i class="bi bi-translate"></i>@(isEnglish ? "TR" : "EN")</a>
                    </div>
                    <div class="user-profile">
                        <div class="user-avatar">AD</div>
                        <div class="user-info">
                            <strong>Admin</strong>
                            <span>@T.Translate("Süper Yönetici", "Super Admin")</span>
                        </div>
                    </div>
                </div>
            </nav>

            <!-- Render Main Content -->
            <main class="content">
                <div class="content-inner">
                    @RenderBody()
                </div>
            </main>

        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar Toggling logic
        function toggleSidebar() {
            if (window.innerWidth < 992) {
                document.body.classList.toggle("sidebar-mobile-open");
                return;
            }
            document.body.classList.toggle("sidebar-collapsed");
        }

        function closeMobileSidebar() {
            document.body.classList.remove("sidebar-mobile-open");
        }

        const desktopToggle = document.getElementById("desktopSidebarToggle");
        const mobileToggle = document.getElementById("mobileSidebarToggle");
        const backdrop = document.getElementById("sidebarBackdrop");

        if (desktopToggle) desktopToggle.addEventListener("click", toggleSidebar);
        if (mobileToggle) mobileToggle.addEventListener("click", toggleSidebar);
        if (backdrop) backdrop.addEventListener("click", closeMobileSidebar);

        window.addEventListener("resize", () => {
            if (window.innerWidth >= 992) {
                closeMobileSidebar();
            }
        });

        const currentPath = window.location.pathname.toLowerCase();
        document.querySelectorAll('.menu-link[href], .submenu-link[href]').forEach(link => {
            const href = (link.getAttribute('href') || '').toLowerCase();
            if (href !== '/' && currentPath.startsWith(href)) {
                link.classList.add('active');
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
